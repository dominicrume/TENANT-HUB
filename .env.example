# ── Supabase (server) ────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=            # NEVER expose to browser; keep only in .env.local

# ── Supabase (public / browser-safe) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── AI (one of these is required for AI features) ────────────────────
RUNCRATE_API_KEY=                      # rc_live_...  (Default, overrides OpenAI/Claude)
ANTHROPIC_API_KEY=                    # sk-ant-...
OPENAI_API_KEY=                       # sk-proj-...  (used when no Anthropic/RunCrate key is set)

# ── Blockchain (optional — async Polygon stamp) ─────────────────────
POLYGON_RPC_URL=
STAMP_WALLET_PRIVATE_KEY=

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Tenant Hub"
NEXT_PUBLIC_APP_VERSION=1.0.0
